# Example environment variables for movie-search-bot
# Copy this file to `.env` and fill in real values.

# Telegram bot token (required for `bot/bot.py`)
BOT_TOKEN=your-telegram-bot-token-here

# Claude / Anthropic API settings (if using Claude or similar model)
# Replace with your provider's API key and endpoint. If using Anthropic,
# set CLAUDE_API_KEY to your API key and optionally CLAUDE_API_URL.
CLAUDE_API_KEY=your-claude-api-key-here
CLAUDE_API_URL=https://api.anthropic.com/v1
CLAUDE_MODEL=claude-instant-v1
CLAUDE_TIMEOUT=30

# Optional behaviour toggles
LOG_LEVEL=INFO